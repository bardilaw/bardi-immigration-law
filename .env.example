# Google Analytics 4
# Get from: GA4 property > Admin > Data Streams > Web stream > Measurement ID (G-XXXXXXXXXX)
NEXT_PUBLIC_GA4_ID=

# Sentry
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# Site
NEXT_PUBLIC_SITE_URL=https://bardiimmigrationlaw.com

# Cal.com consultation booking (BAR-580)
# Booking *slug* only (NOT the full https://cal.com/... URL), e.g. eszter/30-min-consultation.
# Leave blank pre-launch: the /contact pages fall back to the email callback form alone.
# Set both once the attorney's Cal.com account + EN/ES 30-min event types exist, then redeploy.
# NEXT_PUBLIC_* is inlined at build time, so CI must have these set for the embed to render.
NEXT_PUBLIC_CAL_LINK_EN=
NEXT_PUBLIC_CAL_LINK_ES=

# Resend (transactional email)
RESEND_API_KEY=
CONTACT_EMAIL=attorney@bardiimmigrationlaw.com
RESEND_FROM_EMAIL=Bardi Immigration Law <noreply@bardiimmigrationlaw.com>

# Cloudflare
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
